// schemas/rank_list.fbs
namespace Polaris.FbsData;

table RankItem {
    hash:uint32     (id: 0);
    text_key:string (id: 1);
    name:string     (id: 2);
    rank:uint32     (id: 3);
}

table RankGroup {
    group_id:uint32     (id: 0);
    entries:[RankItem]  (id: 1);
}

table RankList {
    entries:[RankGroup] (id: 0);
}

table RankListRoot {
    version:ubyte       (id: 0);
    data:RankList       (id: 1);
}

root_type RankListRoot;
